# Stripe publishable key (pk_live_… or pk_test_…) — safe in client; secret key stays on Laravel server only
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Apple Pay merchant ID (must match Apple Developer + Stripe Dashboard live certificate)
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=merchant.com.tandilapp.uae

# Google Sign-In (client auth) — create OAuth clients at https://console.cloud.google.com/
# iOS client: bundle id com.tandilapp.tandil
# Use one id for all platforms, or set platform-specific ids below.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# Optional — profile Share / Rate the App
# EXPO_PUBLIC_IOS_APP_STORE_ID=1234567890
# EXPO_PUBLIC_SHARE_APP_URL=https://apps.apple.com/app/id1234567890
